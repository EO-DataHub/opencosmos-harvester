{
  "MENUT-L1A": {
    "collection_name": "menut-l1a-cogs",
    "url": "https://app.open-cosmos.com/api/data/v0/stac/",
    "limit": 20,
    "query": {
      "platform": {
        "eq": "menut"
      },
      "processing:level": {
        "eq": "L1A"
      }
    },
    "stac_extensions": [
      "https://stac-extensions.github.io/processing/v1.2.0/schema.json",
      "https://stac-extensions.github.io/sat/v1.1.0/schema.json"
    ]
  }
}
